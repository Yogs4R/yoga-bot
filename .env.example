# Environment Variables for Personal Bot Core

# WhatsApp Configuration
WA_SESSION_DIR=./auth/whatsapp // Directory to store WhatsApp session data
WA_PHONE_NUMBER=YOUR_WHATSAPP_NUMBER // Bot's phone number in international format
BOT_WA_LID=YOUR_BOT_WA_LID // Bot's WhatsApp LID (can be obtained from the session file after first run)

# Telegram Configuration
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN // Bot token obtained from BotFather
TELEGRAM_SESSION_DIR=./auth/telegram // Directory to store Telegram session data
TELEGRAM_BOT_USERNAME=YOUR_TELEGRAM_BOT_USERNAME // Bot username on Telegram

# Google APIs
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID // Client ID for Google APIs (for OAuth2 authentication)
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET // Client Secret for Google APIs (for OAuth2 authentication)
GOOGLE_REDIRECT_URI=YOUR_GOOGLE_REDIRECT_URI // Redirect URI for Google OAuth2 (must match the one set in Google Cloud Console)
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY // API key for Google APIs (for non-authenticated requests, e.g., YouTube Data API)

# Gemini AI
GEMINI_API_KEY=YOUR_GEMINI_API_KEY // API key for Google Gemini AI
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY // API key for OpenRouter (alternative to Gemini AI, can be used for various AI models)

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY // Your Supabase publishable key (for client-side use)
SUPABASE_SECRET_KEY=YOUR_SUPABASE_SECRET_KEY // Your Supabase secret key (for server-side use, keep this secret!)

# Finance API (example)
FINANCE_API_KEY=YOUR_FINANCE_API_KEY // API key for a finance data provider (e.g., Alpha Vantage, Finnhub, etc.)

# Weather API
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY // API key for OpenWeatherMap

# Server Monitor
MONITOR_URLS=https://example.com,https://api.example.com // Comma-separated list of URLs to monitor
MONITOR_INTERVAL=300000 // Interval in milliseconds for monitoring (e.g., 300000 for 5 minutes)

# Admin
ADMIN_TELE_IDS=123456789,987654321 // Comma-separated list of Telegram user IDs for admins
ADMIN_WA_NUMBERS=6281234567890,6280987654321 // Comma-separated list of WhatsApp numbers for admins (in international format)

# Converter Tools
REMOVEBG_API_KEY=YOUR_REMOVEBG_API_KEY // API key for Remove.bg (background removal service)
HCTI_USER_ID=YOUR_HCTI_USER_ID // User ID for HTML/CSS to Image API (HCTI)
HCTI_API_KEY=YOUR_HCTI_API_KEY // API key for HCTI
CLOUDCONVERT_API_KEY=YOUR_CLOUDCONVERT_API_KEY // API key for CloudConvert

# Github Action
AUTO_BROADCAST_RELEASE = YOUR_GITHUB_ACTION_SECRET // Action secret and variabels for auto broadcasting new github releases to Telegram and WhatsApp channels with /broadcast command

# Other
NODE_ENV=development // Set to 'production' in production environment
PORT=3000 // Port for any web server or API endpoints (if needed)