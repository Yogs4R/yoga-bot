# Environment Variables for Personal Bot Core

# WhatsApp Configuration
WA_SESSION_DIR=./auth/whatsapp
WA_PHONE_NUMBER=YOUR_WHATSAPP_NUMBER
BOT_WA_LID=YOUR_BOT_WA_LID

# Telegram Configuration
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_SESSION_DIR=./auth/telegram
TELEGRAM_BOT_USERNAME=YOUR_TELEGRAM_BOT_USERNAME

# Google APIs
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=YOUR_GOOGLE_REDIRECT_URI
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY

# Gemini AI
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
SUPABASE_SECRET_KEY=YOUR_SUPABASE_SECRET_KEY

# Finance API (example)
FINANCE_API_KEY=YOUR_FINANCE_API_KEY

# Weather API
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY

# Server Monitor
MONITOR_URLS=https://example.com,https://api.example.com
MONITOR_INTERVAL=300000

# Admin
ADMIN_TELE_IDS=123456789,987654321
ADMIN_WA_NUMBERS=6281234567890,6280987654321

# Converter Tools
REMOVEBG_API_KEY=YOUR_REMOVEBG_API_KEY
HCTI_USER_ID=YOUR_HCTI_USER_ID
HCTI_API_KEY=YOUR_HCTI_API_KEY
CLOUDCONVERT_API_KEY=YOUR_CLOUDCONVERT_API_KEY

# Github Action
AUTO_BROADCAST_RELEASE=YOUR_GITHUB_ACTION_SECRET

# Other
NODE_ENV=development
PORT=3000