{
  "categories": [
    {
      "title": "What's New",
      "labels": ["feature"]
    },
    {
      "title": "Bug Fixes",
      "labels": ["bug"]
    },
    {
      "title": "Maintenance & Refactor",
      "labels": ["maintenance"]
    },
    {
      "title": "Documentation",
      "labels": ["documentation"]
    }
  ],
  "label_extractors": [
    {
      "pattern": "^feat(?:\\([^)]*\\))?!?:\\s.*",
      "target": "feature",
      "flags": "i"
    },
    {
      "pattern": "^fix(?:\\([^)]*\\))?!?:\\s.*",
      "target": "bug",
      "flags": "i"
    },
    {
      "pattern": "^(?:refactor|chore)(?:\\([^)]*\\))?!?:\\s.*",
      "target": "maintenance",
      "flags": "i"
    },
    {
      "pattern": "^(?:docs(?:\\([^)]*\\))?!?:\\s.*|merge\\b.*|add files via upload.*)",
      "target": "documentation",
      "flags": "i"
    }
  ],
  "ignore_labels": [
    "documentation"
  ],
  "template": "#{{CHANGELOG}}\n\n---\n*Note: This changelog was automatically generated from commit messages.*"
}