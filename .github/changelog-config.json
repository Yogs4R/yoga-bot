{
  "categories": [
    {
      "title": "## 🚀 What's New",
      "labels": ["feature"]
    },
    {
      "title": "## 🐛 Bug Fixes",
      "labels": ["bug"]
    },
    {
      "title": "## 🛠 Maintenance & Refactor",
      "labels": ["maintenance"]
    },
    {
      "title": "## 📚 Documentation",
      "labels": ["documentation"]
    }
  ],
  "label_extractors": [
    {
      "pattern": "^feat(?:\\([^)]*\\))?!?:\\s.*",
      "target": "feature",
      "on_property": "message",
      "flags": "i"
    },
    {
      "pattern": "^fix(?:\\([^)]*\\))?!?:\\s.*",
      "target": "bug",
      "on_property": "message",
      "flags": "i"
    },
    {
      "pattern": "^(?:refactor|chore)(?:\\([^)]*\\))?!?:\\s.*",
      "target": "maintenance",
      "on_property": "message",
      "flags": "i"
    },
    {
      "pattern": "^(?:docs(?:\\([^)]*\\))?!?:\\s.*|merge\\b.*|add files via upload.*)",
      "target": "documentation",
      "on_property": "message",
      "flags": "i"
    }
  ],
  "ignore_labels": [
    "documentation"
  ],
  "commit_template": "- #{{TITLE}} (#{{HASH}})",
  "template": "#{{CHANGELOG}}\n\n### ❓ Other Changes\n#{{UNCATEGORIZED}}\n\n---\n*Note: This changelog was automatically generated from commit messages.*"
}